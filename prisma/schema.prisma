generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

model User {
  id               BigInt            @id @default(autoincrement())
  fullName         String            @db.VarChar
  email            String            @unique @db.VarChar
  password         String            @db.VarChar
  avatar           String?           @db.VarChar
  role             Boolean           @default(true)
  createdAt        DateTime          @db.Date
  isBlocked        Boolean?          @default(false)

  reviews          Review[]
  itineraries      Itinerary[]
  explorePosts     ExplorePost[]
  explorePostLikes ExplorePostLike[]
  forumPosts       ForumPost[]
  forumComments    ForumComment[]
  forumLikes       ForumLike[]
  forumSaves       ForumSave[]
  chatSessions     ChatSession[]

  @@map("User")
}

model Category {
  id       BigInt @id @default(autoincrement())
  name     String
  iconCode Int?

  places Place[]

  @@map("Category")
}

model Place {
  id              BigInt    @id @default(autoincrement())
  name            String    @db.VarChar
  description     String    @db.VarChar
  latitude        Float
  longitude       Float
  address         String    @db.VarChar
  price           String    @db.VarChar
  categoryId      BigInt
  image           String    @db.VarChar
  rating          Float?
  userRatingCount Int?
  externalId      String?   @unique @db.VarChar(100)
  phone           String?   @db.VarChar(50)
  website         String?   @db.VarChar(255)
  priceLevel      String?   @db.VarChar(10)
  openingHours    Json?
  subCategories   Json?
  tripadvisorUrl  String?
  lastSyncedAt    DateTime? @default(now()) @db.Timestamp(6)
  isApproved      Boolean?  @default(true)

  category             Category              @relation(fields: [categoryId], references: [id])
  reviews              Review[]
  photos               PlacePhoto[]
  itinerarySavedPlaces ItinerarySavedPlace[]
  itineraryDetails     ItineraryDetail[]
  explorePostItems     ExplorePostItem[]
  forumPosts           ForumPost[]

  @@map("Place")
}

model Review {
  id               BigInt    @id @default(autoincrement())
  rating           Float     @db.Real
  comment          String    @db.VarChar
  userId           BigInt?
  placeId          BigInt
  externalReviewId String?   @unique @db.VarChar(100)
  authorName       String?   @db.VarChar(150)
  authorAvatar     String?   @db.VarChar(255)
  authorLocation   String?   @db.VarChar(150)
  publishedDate    DateTime? @db.Date
  source           String?   @default("LOCAL") @db.VarChar(20)

  place            Place             @relation(fields: [placeId], references: [id])
  user             User?             @relation(fields: [userId], references: [id])
  explorePostItems ExplorePostItem[]

  @@map("Review")
}

model Itinerary {
  id          BigInt   @id @default(autoincrement())
  title       String   @db.VarChar
  startDate   DateTime @db.Date
  days        BigInt?
  budget      BigInt?
  userId      BigInt
  destination String   @db.VarChar
  companion   String?  @db.VarChar
  pace        String?  @db.VarChar
  categories  String[]
  amenities   String[]
  dayConfigs  Json     @default("{}")
  isGuide     Boolean? @default(false)
  coverImage  String?

  user         User                  @relation(fields: [userId], references: [id])
  savedPlaces  ItinerarySavedPlace[]
  details      ItineraryDetail[]
  sections     ItinerarySection[]
  explorePosts ExplorePost[]

  @@map("Itinerary")
}

model PlacePhoto {
  id           BigInt  @id @default(autoincrement())
  placeId      BigInt
  urlOriginal  String  @db.VarChar(500)
  urlThumbnail String? @db.VarChar(500)
  caption      String?
  source       String? @default("TRIPADVISOR") @db.VarChar(20)

  place Place @relation(fields: [placeId], references: [id])

  @@map("PlacePhoto")
}

model ItinerarySavedPlace {
  id          BigInt   @id(map: "itinerarysavedplace_pkey") @default(autoincrement())
  itineraryId BigInt
  placeId     BigInt?
  section     String   @db.VarChar
  noteText    String?
  reactions   Json     @default("[]")
  isCollapsed Boolean  @default(false)
  sortOrder   Int      @default(0)
  todoItems   Json     @default("[]")
  startTime   String?
  endTime     String?
  isVisited   Boolean? @default(false) @map("is_visited")
  cost        Decimal? @default(0) @db.Decimal(12, 2)
  attachments Json     @default("[]")

  itinerary Itinerary @relation(fields: [itineraryId], references: [id])
  place     Place?    @relation(fields: [placeId], references: [id])

  @@map("ItinerarySavedPlace")
}

model ItineraryDetail {
  id          BigInt   @id(map: "itinerarydetail_pkey") @default(autoincrement())
  day         Int
  sortOrder   Int      @default(0)
  placeId     BigInt?
  itineraryId BigInt
  noteText    String?
  todoItems   Json     @default("[]")
  reactions   Json     @default("[]")
  isCollapsed Boolean  @default(false)
  isVisited   Boolean? @default(false) @map("is_visited")
  cost        Decimal? @default(0) @db.Decimal(12, 2)
  attachments Json     @default("[]")
  startTime   String?
  endTime     String?

  itinerary Itinerary @relation(fields: [itineraryId], references: [id])
  place     Place?    @relation(fields: [placeId], references: [id])

  @@map("ItineraryDetail")
}

model ChecklistTemplateCategory {
  id      BigInt @id(map: "checklisttemplatecategory_pkey") @default(autoincrement())
  name    String @db.VarChar
  tabType String @db.VarChar

  items ChecklistTemplateItem[]

  @@map("ChecklistTemplateCategory")
}

model ChecklistTemplateItem {
  id         BigInt @id(map: "checklisttemplateitem_pkey") @default(autoincrement())
  categoryId BigInt
  name       String @db.VarChar

  category ChecklistTemplateCategory @relation(fields: [categoryId], references: [id])

  @@map("ChecklistTemplateItem")
}

model ItinerarySection {
  id          BigInt  @id @default(autoincrement())
  itineraryId BigInt
  name        String  @db.VarChar
  subTitle    String? @db.VarChar
  colorCode   String? @db.VarChar
  iconCode    Int?
  sortOrder   Int     @default(0)
  sectionType String  @default("LIST") @db.VarChar

  itinerary Itinerary @relation(fields: [itineraryId], references: [id])
}

model WeatherCache {
  id          BigInt   @id @default(autoincrement())
  cityName    String   @unique @db.VarChar(150)
  latitude    Float
  longitude   Float
  temp        Float
  humidity    Int
  windSpeed   Float
  condition   String
  description String
  icon        String
  rawResponse Json
  updatedAt   DateTime @default(now()) @updatedAt

  @@map("WeatherCache")
}

model ExplorePost {
  id                  BigInt            @id @default(autoincrement())
  title               String
  description         String?
  coverImage          String?
  postType            String
  authorId            BigInt?
  originalItineraryId BigInt?
  platformName        String?
  platformLogo        String?
  platformUrl         String?
  viewCount           Int               @default(0)
  likeCount           Int               @default(0)
  shareCount          Int               @default(0)
  destination         String?
  status              String            @default("PUBLISHED")
  createdAt           DateTime          @default(now()) @db.Timestamp(6)
  updatedAt           DateTime          @updatedAt @db.Timestamp(6)
  author              User?             @relation(fields: [authorId], references: [id])
  originalItinerary   Itinerary?        @relation(fields: [originalItineraryId], references: [id])
  items               ExplorePostItem[]
  likes               ExplorePostLike[]

  @@map("ExplorePost")
}

model ExplorePostItem {
  id               BigInt      @id @default(autoincrement())
  postId           BigInt
  itemType         String
  sortOrder        Int
  content          String?
  placeId          BigInt?
  featuredReviewId BigInt?
  featuredReview   Review?     @relation(fields: [featuredReviewId], references: [id])
  place            Place?      @relation(fields: [placeId], references: [id])
  post             ExplorePost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("ExplorePostItem")
}

model ExplorePostLike {
  postId    BigInt
  userId    BigInt
  createdAt DateTime    @default(now()) @db.Timestamp(6)
  post      ExplorePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@map("ExplorePostLike")
}

// ==========================================
// NEW FORUM MODELS
// ==========================================

// Bảng bài đăng trong diễn đàn
model ForumPost {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  content     String   @db.Text
  placeId     BigInt?  // Địa điểm được gắn thẻ (nullable)
  viewCount   Int      @default(0)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @db.Timestamp(6)
  editedAt    DateTime? @db.Timestamp(6)

  // Mối quan hệ
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  place       Place?         @relation(fields: [placeId], references: [id], onDelete: SetNull)
  media       ForumMedia[]
  comments    ForumComment[]
  likes       ForumLike[]
  saves       ForumSave[]

  @@map("ForumPost")
}

// Bảng chứa hình ảnh / video đính kèm bài viết
model ForumMedia {
  id        BigInt   @id @default(autoincrement())
  postId    BigInt
  url       String
  mediaType String   // 'IMAGE' hoặc 'VIDEO'
  sortOrder Int      @default(0)

  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("ForumMedia")
}

// Bảng bình luận bài viết
model ForumComment {
  id        BigInt    @id @default(autoincrement())
  postId    BigInt
  userId    BigInt
  content   String    @db.Text
  mediaUrl  String?
  mediaType String?   // 'IMAGE' hoặc 'VIDEO'
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  editedAt  DateTime? @db.Timestamp(6)

  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ForumComment")
}

// Bảng thả tim (Like) - Sử dụng Composite Primary Key để tránh trùng lặp
model ForumLike {
  postId    BigInt
  userId    BigInt
  createdAt DateTime @default(now()) @db.Timestamp(6)

  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@map("ForumLike")
}

// Bảng lưu bài viết (Save/Bookmark)
model ForumSave {
  postId    BigInt
  userId    BigInt
  createdAt DateTime @default(now()) @db.Timestamp(6)

  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@map("ForumSave")
}

// ==========================================
// AI CHAT MODELS
// ==========================================

model ChatSession {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  title       String?  @db.VarChar
  destination String?  @db.VarChar
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @db.Timestamp(6)

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]

  @@map("ChatSession")
}

model ChatMessage {
  id          BigInt   @id @default(autoincrement())
  sessionId   BigInt
  role        String   @db.VarChar(50) // 'USER' or 'AI'
  content     String   @db.Text
  createdAt   DateTime @default(now()) @db.Timestamp(6)

  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("ChatMessage")
}
